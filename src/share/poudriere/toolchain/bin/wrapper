#!/bin/sh

die() {
	echo "${*}" >&2
	exit 1
}

TOOLCHAIN_ROOTDIR="/toolchain"
TOOLCHAIN_LOCALBASE="${TOOLCHAIN_ROOTDIR}/usr/local64"
TOOLCHAIN_LOCALBASE_BIN="${TOOLCHAIN_LOCALBASE}/bin"
TOOLCHAIN_LOCALBASE_LIB="${TOOLCHAIN_LOCALBASE}/lib"

#
# Get information on a toolchain program being executed and a target
# architecture.
#
# basename(1) and sysctl(8) must be executed before LD_LIBRARY_PATH is set.
#
prog=$(basename "${0}")
if [ -z "${MACHINE_ARCH}" ]; then
	arch="$(sysctl -n hw.machine_arch)"
else
	arch="${MACHINE_ARCH}"
fi

#
# Compute toolchain flags.
#
if [ -n "${QEMU_EMULATING}" ]; then
	# Explicitly build for the aarch64 target.
	# The toolchain targets the native architecture by default.
	arch_cflags="-target aarch64-unknown-freebsd15.0"
else
	arch_cflags=""
fi
case "${arch}" in
aarch64)
	if [ -z "${MACHINE_ARCH_HYBRID}" ]; then
		# Build for vanilla aarch64 which can be used on
		# CheriBSD/Morello and FreeBSD/arm64.
		arch_cflags="${arch_cflags} -march=morello+noa64c"
	fi
	;;
aarch64*c*)
	if [ "${arch}" = "aarch64cb" ]; then
		# Explicitly build for purecap-benchmark.
		# llvm-morello's toolchain cannot detect that as the rootfs is
		# built for purecap.
		arch_cflags="${arch_cflags} -mabi=purecap-benchmark"
	fi
	;;
riscv64|riscv64c)
	;;
*)
	die "Unexpected architecture: ${arch}"
	;;
esac
arch_cppflags="${arch_cflags}"
# Pass the --undefined-version flag to the linker. LLVM 17 changes the default
# for that and our ports versions do not build without it.
arch_cflags="${arch_cflags} -Wl,--undefined-version"
arch_linkerflags="--undefined-version"

#
# Use a toolchain from LLVM for Morello for AArch64-based architectures.
# Otherwise, use CHERI LLVM.
#
case "${arch}" in
aarch64*)
	TOOLCHAIN_SUFFIX="morello"
	;;
*)
	TOOLCHAIN_SUFFIX="cheri"
	;;
esac

#
# Use toolchain libraries and base system libraries from a jail or a host,
# if the jail is emulated.
#
_LD_LIBRARY_PATH="${TOOLCHAIN_LOCALBASE_LIB}"
if [ -n "${QEMU_EMULATING}" ]; then
	TOOLCHAIN_BASE_LIB="/host/usr/local/lib:/host/usr/lib:/host/lib"
	_LD_LIBRARY_PATH="${_LD_LIBRARY_PATH}:${TOOLCHAIN_BASE_LIB}"
fi
if [ -n "${QEMU_EMULATING}" ]; then
	export LD_LIBRARY_PATH="${_LD_LIBRARY_PATH}"
else
	case "${arch}" in
	aarch64|riscv64)
		export LD_LIBRARY_PATH="${_LD_LIBRARY_PATH}"
		;;
	aarch64*c*|riscv64*c*)
		export LD_64_LIBRARY_PATH="${_LD_LIBRARY_PATH}"
		;;
	esac
fi

#
# Overwrite variables from make.conf so that subprocesses directly utilities.
#
export ADDR2LINE="${TOOLCHAIN_LOCALBASE_BIN}/llvm-addr2line-${TOOLCHAIN_SUFFIX}"
export AR="${TOOLCHAIN_LOCALBASE_BIN}/llvm-ar-${TOOLCHAIN_SUFFIX}"
export CC="${TOOLCHAIN_LOCALBASE_BIN}/clang-${TOOLCHAIN_SUFFIX} ${arch_cflags}"
export CPP="${TOOLCHAIN_LOCALBASE_BIN}/clang-cpp-${TOOLCHAIN_SUFFIX} ${arch_cppflags}"
export CPPFILT="${TOOLCHAIN_LOCALBASE_BIN}/llvm-cxxfilt-${TOOLCHAIN_SUFFIX}"
export CXX="${TOOLCHAIN_LOCALBASE_BIN}/clang++-${TOOLCHAIN_SUFFIX} ${arch_cflags}"
export AS="${CC}"
export LD="${TOOLCHAIN_LOCALBASE_BIN}/ld.lld-${TOOLCHAIN_SUFFIX} ${arch_linkerflags}"
export NM="${TOOLCHAIN_LOCALBASE_BIN}/llvm-nm-${TOOLCHAIN_SUFFIX}"
export OBJCOPY="${TOOLCHAIN_LOCALBASE_BIN}/llvm-objcopy-${TOOLCHAIN_SUFFIX}"
export OBJDUMP="${TOOLCHAIN_LOCALBASE_BIN}/llvm-objdump-${TOOLCHAIN_SUFFIX}"
export RANLIB="${TOOLCHAIN_LOCALBASE_BIN}/llvm-ranlib-${TOOLCHAIN_SUFFIX}"
export READELF="${TOOLCHAIN_LOCALBASE_BIN}/llvm-readelf-${TOOLCHAIN_SUFFIX}"
export SIZE="${TOOLCHAIN_LOCALBASE_BIN}/llvm-size-${TOOLCHAIN_SUFFIX}"
export STRINGS="${TOOLCHAIN_LOCALBASE_BIN}/llvm-strings-${TOOLCHAIN_SUFFIX}"
export STRIP="${TOOLCHAIN_LOCALBASE_BIN}/llvm-strip-${TOOLCHAIN_SUFFIX}"
export XCC="${CC}"
export XCPP="${CPP}"
export XCXX="${CXX}"

#
# Point the toolchain wrapper at the correct root directory.
#
export _LLVM_ROOTDIR="${TOOLCHAIN_ROOTDIR}"

#
# Finally, execute the program.
#
case "${prog}" in
addr2line)
	${ADDR2LINE} "${@}"
	;;
ar)
	${AR} "${@}"
	;;
as)
	${AS} "${@}"
	;;
c++|clang++)
	${CXX} "${@}"
	;;
c++filt)
	${CPPFILT} "${@}"
	;;
cc|clang)
	${CC} "${@}"
	;;
cpp|clang-cpp)
	${CPP} "${@}"
	;;
ld)
	${LD} "${@}"
	;;
nm)
	${NM} "${@}"
	;;
objcopy)
	${OBJCOPY} "${@}"
	;;
objdump)
	${OBJDUMP} "${@}"
	;;
ranlib)
	${RANLIB} "${@}"
	;;
readelf)
	${READELF} "${@}"
	;;
size)
	${SIZE} "${@}"
	;;
strings)
	${STRINGS} "${@}"
	;;
strip)
	${STRIP} "${@}"
	;;
*)
	die "Unexpected program: ${prog}."
	;;
esac
